<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GlobusLens" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    !-- Splash Screen Theme (for Android 12+) -->
    <style name="Theme.GlobusLens.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.GlobusLens</item>
    </style>

    <!-- Dark theme variant (optional) -->
    <style name="Theme.GlobusLens.Dark" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>